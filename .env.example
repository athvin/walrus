# .env.example — copy to .env (`cp .env.example .env`) for local dev.
#
# The WALRUS_* keys map 1:1 onto common::CommonConfig (PR 0.5): WALRUS_<FIELD>, with `__` for
# nesting (e.g. WALRUS_OBJECT_STORE__BUCKET -> object_store.bucket). Values line up with
# deploy/docker/docker-compose.yml, so a fresh `.env` yields a config that loads and validates.

# --- common::CommonConfig ---
WALRUS_CONTROL_DB_URL=postgres://postgres:postgres@localhost:5433/walrus_control
WALRUS_OBJECT_STORE__BUCKET=walrus
WALRUS_OBJECT_STORE__ENDPOINT=http://localhost:9000
WALRUS_OBJECT_STORE__REGION=us-east-1
WALRUS_STARTUP_DEADLINE=60s
WALRUS_INSTANCE=walrus-dev-0
# Optional logging knobs (default: pretty formatter, "info"):
# WALRUS_TELEMETRY__JSON=false
# WALRUS_TELEMETRY__FILTER=info,walrus=debug

# --- object-store credentials (consumed by the S3 client, not by CommonConfig) ---
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
